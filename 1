class ProxyManager:
    """Продвинутый менеджер прокси с ротацией"""
    
    def __init__(self):
        self.proxies = []
        self.current_index = 0
        self.lock = threading.Lock()
        
    def load_proxies(self, proxy_file: str = None):
        """Загрузка прокси из файла или генерация"""
        if proxy_file and os.path.exists(proxy_file):
            with open(proxy_file, 'r') as f:
                for line in f:
                    line = line.strip()
                    if line:
                        self.proxies.append(self._parse_proxy(line))
        
        # Добавляем SOCKS5 прокси если нет
        if len(self.proxies) < 10:
            self._generate_socks_proxies()
            
        print(f"{Fore.GREEN}[+] Loaded {len(self.proxies)} proxies")
    
    def _parse_proxy(self, proxy_str: str) -> dict:
        """Парсинг прокси строки"""
        if proxy_str.startswith('http://'):
            return {'http': proxy_str, 'https': proxy_str}
        elif proxy_str.startswith('socks5://'):
            return {'http': proxy_str, 'https': proxy_str}
        else:
            return {'http': f'http://{proxy_str}', 'https': f'http://{proxy_str}'}
    
    def _generate_socks_proxies(self):
        """Генерация/получение SOCKS5 прокси"""
        # В реальном скрипте здесь будет получение прокси из различных источников
        pass
    
    def get_proxy(self) -> dict:
        """Получение случайного прокси с ротацией"""
        with self.lock:
            if not self.proxies:
                return None
            self.current_index = (self.current_index + 1) % len(self.proxies)
            return self.proxies[self.current_index]

