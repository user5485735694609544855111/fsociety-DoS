class WAFBypass:
    """Обход WAF и других защит"""
    
    @staticmethod
    def random_case(text: str) -> str:
        """Случайный регистр"""
        return ''.join(random.choice([c.upper(), c.lower()]) for c in text)
    
    @staticmethod
    def add_padding(text: str) -> str:
        """Добавление паддинга"""
        padding = ''.join(random.choices('/./', k=random.randint(0, 5)))
        return f"{padding}{text}{padding}"
    
    @staticmethod
    def encode_payload(payload: str) -> str:
        """Множественное кодирование"""
        encodings = [
            lambda x: base64.b64encode(x.encode()).decode(),
            lambda x: urllib.parse.quote(x),
            lambda x: x.encode('utf-8').hex()
        ]
        return random.choice(encodings)(payload)

